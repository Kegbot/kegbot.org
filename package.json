{
  "name": "kegbot-org",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "lint": "bunx @biomejs/biome check --apply .",
    "deploy": "bunx wrangler deploy"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.13.5",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.13.5",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@plausible-analytics/tracker": "^0.4.4",
    "react": "^19",
    "react-dom": "^19",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@cloudflare/vite-plugin": "^1.28.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "wrangler": "^4.73.0"
  }
}
